# ────────────────────────────────────────────────────────
#   HeliosAE — AERIS Nexus
#   Konfigurasi API Provider
#
#   Salin file ini ke ~/.helios/.env dan isi API key kamu.
#   Butuh MINIMAL SATU dari dua key berikut.
# ────────────────────────────────────────────────────────

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Model default: gemini-2.5-flash-preview-04-17
#   → Gemini 2.5 Flash: cepat + kemampuan thinking, 1 JUTA context window, GRATIS
#   → Daftar & ambil key: https://aistudio.google.com/app/apikey
#
# Cara taruh API key:
#   1. Buka https://aistudio.google.com/app/apikey
#   2. Klik "Create API Key"
#   3. Copy key-nya, paste di bawah ini (hapus tanda # di depan)
GEMINI_API_KEY=

# ── Groq ──────────────────────────────────────────────────────────────────────
# Model default: llama-3.3-70b-versatile
#   → Super cepat, response hampir real-time, GRATIS
#   → Daftar & ambil key: https://console.groq.com/keys
#
# Cara taruh API key:
#   1. Buka https://console.groq.com/keys
#   2. Klik "Create API Key"
#   3. Copy key-nya, paste di bawah ini (hapus tanda # di depan)
GROQ_API_KEY=

# ── Provider selector (optional) ──────────────────────────────────────────────
# auto   = Smart routing: Groq (cepat) ↔ Gemini 2.5 Flash (long context/complex)
# gemini = Selalu pakai Gemini
# groq   = Selalu pakai Groq
# HELIOS_PROVIDER=auto

# ── Model override (optional) ─────────────────────────────────────────────────
# Override model default. Apapun modelnya, Helios tetap tahu siapa dia
# dan tetap bisa menggunakan semua tools HeliosAE.
# Contoh Gemini: gemini-2.5-pro-exp-03-25, gemini-2.0-flash, gemini-2.0-flash-lite
# Contoh Groq:   llama-3.1-8b-instant, deepseek-r1-distill-llama-70b
# HELIOS_MODEL=

# ── Smart routing (optional) ──────────────────────────────────────────────────
# 1 (default) = aktif — otomatis switch Groq↔Gemini berdasarkan context size
# 0           = nonaktif — tetap di provider yang dipilih
# HELIOS_SMART_ROUTE=1
